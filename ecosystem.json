{
    "apps": [
      {
        "name": "Dissonant Voices Beta",
        "script": "dist/index.js",
        "cwd": "server",
        "env_production": {
          "NODE_ENV": "production"
        }
      }
    ],
    "deploy": {
      "production": {
        "user": "north101",
        "host": ["north101.co.uk"],
        "ref": "origin/workspaces",
        "repo": "https://github.com/North101/dissonant_voices.git",
        "path": "/home/north101/dissonant_voices_beta",
        "post-deploy": "yarn install && yarn --cwd server run build && ln -sfn ./client/build/ ./server/public && pm2 startOrRestart ecosystem.json --env production"
      }
    }
  }